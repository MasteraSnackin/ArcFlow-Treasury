# ── Contract deployment ────────────────────────────────────────────────────────
ARC_TESTNET_RPC_URL=https://rpc.arcprotocol.xyz/testnet   # Arc Testnet RPC
ARC_PRIVATE_KEY=0x<64-hex-chars>                          # Deployer wallet private key
ARC_FEE_COLLECTOR=                                         # Leave blank → defaults to deployer
ARC_FEE_BPS=0                                              # Protocol fee basis points (0 = none)

# ── Backend ────────────────────────────────────────────────────────────────────
ARC_ESCROW_ADDRESS=                                        # Output of npm run deploy:arc
ARC_STREAMS_ADDRESS=
ARC_PAYOUT_ROUTER_ADDRESS=
