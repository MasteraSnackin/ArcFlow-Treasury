# ArcFlow Backend — environment variables
# Copy this file to .env and fill in the values.

PORT=3000

# Circle API credentials (leave blank to run in stub mode)
CIRCLE_API_KEY=
CIRCLE_WALLET_ID=
CIRCLE_ENTITY_SECRET=
CIRCLE_WEBHOOK_SECRET=

# Optional: persist the payout store to a JSON file so data survives restarts.
# Relative paths are resolved from the directory where the server is started.
# Leave blank to use in-memory only (data lost on restart).
PAYOUT_STORE_PATH=./data/payouts.json

# Arc Testnet RPC (set by deploy script or manually)
ARC_TESTNET_RPC_URL=
ARC_PRIVATE_KEY=
ARC_FEE_COLLECTOR=
ARC_FEE_BPS=

# Contract addresses — output of `npm run deploy:arc`
ARC_ESCROW_ADDRESS=
ARC_STREAMS_ADDRESS=
ARC_PAYOUT_ROUTER_ADDRESS=

# Circle CCTP cross-chain — USDC token address on Arc Testnet source chain
CIRCLE_BURN_TOKEN_ADDRESS=
