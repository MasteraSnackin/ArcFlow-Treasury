# Arc Testnet Configuration
ARC_TESTNET_RPC_URL=https://your-arc-testnet-rpc
ARC_PAYOUT_ROUTER_ADDRESS=0xYourDeployedPayoutRouterAddress

# Server Configuration
PORT=3000
NODE_ENV=development

# ---------------------------------------------------------------------------
# Circle API Configuration
#
# Both variables are required by the Circle Developer Controlled Wallets SDK
# (initiateDeveloperControlledWalletsClient) — following the pattern in
# circlefin/arc-multichain-wallet (.env.example and lib/circle/sdk.ts).
# ---------------------------------------------------------------------------
CIRCLE_API_KEY=your-circle-api-key
CIRCLE_ENTITY_SECRET=your-circle-entity-secret

# Circle API base URLs (testnet defaults — override for mainnet or local dev)
# Gateway API: cross-chain burn-attest-mint transfers
CIRCLE_GATEWAY_BASE_URL=https://gateway-api-testnet.circle.com/v1
# Wallets API: same-chain developer-controlled wallet transfers and management
CIRCLE_WALLETS_BASE_URL=https://api.circle.com/v1

# Logging
LOG_LEVEL=info
