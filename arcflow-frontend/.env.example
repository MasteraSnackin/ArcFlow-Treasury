# ArcFlow Treasury — Frontend environment variables
# Copy this file to .env and fill in the deployed contract addresses.
# Run `cd arcflow-contracts && npm run deploy:arc` to get these addresses.

VITE_ARC_ESCROW_ADDRESS=
VITE_ARC_STREAMS_ADDRESS=
VITE_ARC_PAYOUT_ROUTER_ADDRESS=
VITE_USDC_ADDRESS=
VITE_EURC_ADDRESS=
VITE_BACKEND_URL=                       # e.g. https://arcflow-backend.herokuapp.com
